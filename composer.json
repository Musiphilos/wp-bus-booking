{
    "name": "nvf/bus-booking",
    "description": "Bus booking management using MetaBox CPT and MCP Adapter",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.2",
        "dompdf/dompdf": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "wordpress/mcp-adapter": "*",
        "wordpress/abilities-api": "*"
    },
    "autoload": {
        "psr-4": {
            "NVF\\BusBooking\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NVF\\BusBooking\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "automattic/jetpack-autoloader": true
        },
        "optimize-autoloader": true
    }
}
